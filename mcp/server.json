{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.l10n-dev/ai-l10n-mcp",
  "description": "MCP Server that turns your AI agent into a localization expert with token-efficient i18n translation",
  "repository": {
    "url": "https://github.com/l10n-dev/ai-l10n",
    "source": "github",
    "type": "git",
    "subfolder": "mcp"
  },
  "version": "1.1.2",
  "websiteUrl": "https://l10n.dev",
  "title": "L10n.dev - AI Localization Agent",
  "icons": [
    {
      "src": "https://l10n.dev/favicon.svg",
      "mimeType": "image/svg+xml"
    },
    {
      "src": "https://l10n.dev/favicon-96x96.png",
      "mimeType": "image/png",
      "sizes": [
        "96x96"
      ]
    },
    {
      "src": "https://l10n.dev/apple-touch-icon.png",
      "mimeType": "image/png",
      "sizes": [
        "180x180"
      ]
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "ai-l10n-mcp",
      "version": "1.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}